# rtunnel config (.env style)
# Copy to:
#   ${XDG_CONFIG_HOME:-$HOME/.config}/rtunnel/rtunnel.env

# Enable/disable history features.
# When set to 0, history-related subcommands are hidden in --help and will warn if called.
RTUNNEL_HISTORY_ENABLED=1

# Prefer fzf for interactive history selection (falls back to a numbered prompt).
RTUNNEL_FZF=1

# Default bind address used on the *remote side* of -L local:bind:remote
# Typical values:
#   127.0.0.1  (default, safest)
#   0.0.0.0    (if you need to reach remote services bound to all interfaces—use with care)
RTUNNEL_DEFAULT_BIND=127.0.0.1

# SSH binary (if you want to override)
RTUNNEL_SSH_BIN=ssh

# Override base directory for rtunnel state (active + history)
# RTUNNEL_DIR=$HOME/.config/rtunnel