# rtunnel env example (v0.2.0)
#
# Copy to one of:
#   - $XDG_CONFIG_HOME/rtunnel/rtunnel.env
#   - $HOME/.config/rtunnel/rtunnel.env
# Or point RTUNNEL_ENV_FILE at your custom location.

# Enable/disable history (reopen/favorites depend on history)
RTUNNEL_HISTORY_ENABLED=1

# Use fzf for interactive selection if available (fallback to numbered prompt)
RTUNNEL_FZF=1

# Default bind host used in the ssh -L spec: local_port:BIND:remote_port
# (This is the host on the *remote side* that ssh will connect to.)
RTUNNEL_DEFAULT_BIND=127.0.0.1

# SSH binary to use
RTUNNEL_SSH_BIN=ssh

# Default behavior for 'rtunnel reopen' when no explicit ID is provided:
#   prompt - interactive selection (default)
#   last   - reopen the most recently opened (non-private) history entry
RTUNNEL_REOPEN_DEFAULT=prompt

# Disable warnings (e.g. the warning shown when using --private)
#   0 - warnings enabled (default)
#   1 - warnings disabled
RTUNNEL_NO_WARN=0

# (Optional) Override storage dir (default: ~/.config/rtunnel or $XDG_CONFIG_HOME/rtunnel)
# RTUNNEL_DIR="$HOME/.config/rtunnel"
