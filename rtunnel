#!/usr/bin/env bash
# rtunnel - SSH tunnel manager (bash).
#
# v0.4.0:
# - Add --json output (requires jq) for read+write commands
#   - open/close single -> JSON object
#   - close --all -> JSON array
#   - ls/history/favorites -> JSON array
#
# v0.3.0:
# - open --replace (requires --name; replaces by active name only)
# - close --all, --stale, --force
# - history --name, --favorites, --limit
#
# v0.2.1:
# - "Did you mean?" suggestions (stderr) for name lookups
# - Suggestions suppressible via RTUNNEL_NO_SUGGEST=1 or --no-suggest
#
# v0.2.0:
# - Structured history storage + safe arg replay (no eval)
# - Active-only name uniqueness
# - reopen configurable (prompt/last) + --last override
# - favorites (fav/unfav/favorites)
#
# Private tunnels:
# - --private disables ALL history/state updates
# - Private tunnels cannot be reopened with `rtunnel reopen`
# - A warning is printed unless silenced (RTUNNEL_NO_WARN=1 or --no-warn)

set -Eeuo pipefail
IFS=$'\n\t'

VERSION="0.4.0"

# ---------------- logging helpers ----------------
info() { printf '%s\n' "$*"; }
warn() { printf 'rtunnel: %s\n' "$*" >&2; }
die()  { warn "$*"; exit 1; }
usage_die() { warn "$*"; warn "Try: rtunnel --help"; exit 2; }

have() { command -v "$1" >/dev/null 2>&1; }
is_int() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }
now_iso() { date "+%Y-%m-%dT%H:%M:%S%z"; }

require_jq_for_json() {
  if ! have jq; then
    die "jq is required for --json output (install jq or omit --json)."
  fi
}

# ---------------- config loading ----------------
load_env_file() {
  local f="$1"
  [[ -f "$f" ]] || return 0
  # shellcheck disable=SC1090
  source "$f"
}

init_config() {
  : "${RTUNNEL_HISTORY_ENABLED:=1}"
  : "${RTUNNEL_FZF:=1}"
  : "${RTUNNEL_DEFAULT_BIND:=127.0.0.1}"
  : "${RTUNNEL_SSH_BIN:=ssh}"
  : "${RTUNNEL_REOPEN_DEFAULT:=prompt}"  # prompt|last
  : "${RTUNNEL_NO_WARN:=0}"              # 1 disables warnings
  : "${RTUNNEL_NO_SUGGEST:=0}"           # 1 disables "Did you mean?" suggestions

  if [[ "${RTUNNEL_ENV_FILE:-}" != "" ]]; then
    load_env_file "$RTUNNEL_ENV_FILE"
  else
    local base="${XDG_CONFIG_HOME:-$HOME/.config}"
    load_env_file "$base/rtunnel/rtunnel.env"
    load_env_file "$HOME/.config/rtunnel/rtunnel.env"
  fi

  : "${RTUNNEL_DIR:=${XDG_CONFIG_HOME:-$HOME/.config}/rtunnel}"
  : "${RTUNNEL_ACTIVE_DIR:=$RTUNNEL_DIR/active}"
  : "${RTUNNEL_HISTORY_DIR:=$RTUNNEL_DIR/history}"
  : "${RTUNNEL_STATE_DIR:=$RTUNNEL_DIR/state}"
  : "${RTUNNEL_NEXT_ID_FILE:=$RTUNNEL_DIR/next-id}"

  mkdir -p "$RTUNNEL_ACTIVE_DIR" "$RTUNNEL_HISTORY_DIR" "$RTUNNEL_STATE_DIR" "$RTUNNEL_DIR"
  chmod 700 "$RTUNNEL_DIR" "$RTUNNEL_ACTIVE_DIR" "$RTUNNEL_HISTORY_DIR" "$RTUNNEL_STATE_DIR" 2>/dev/null || true

  if [[ ! -f "$RTUNNEL_NEXT_ID_FILE" ]]; then
    printf '1\n' >"$RTUNNEL_NEXT_ID_FILE"
    chmod 600 "$RTUNNEL_NEXT_ID_FILE" 2>/dev/null || true
  fi
}

# ---------------- state helpers ----------------
state_set() {
  local key="$1" val="$2"
  local f="$RTUNNEL_STATE_DIR/$key"
  printf '%s\n' "$val" >"$f"
  chmod 600 "$f" 2>/dev/null || true
}

state_get() {
  local key="$1"
  local f="$RTUNNEL_STATE_DIR/$key"
  [[ -f "$f" ]] || return 1
  local v
  v="$(cat "$f" 2>/dev/null || true)"
  [[ -n "$v" ]] || return 1
  printf '%s\n' "$v"
}

load_kv_file() {
  local f="$1"
  [[ -f "$f" ]] || return 1
  # shellcheck disable=SC1090
  source "$f"
}

warnings_enabled() { [[ "${RTUNNEL_NO_WARN}" != "1" ]]; }
suggestions_enabled() { [[ "${RTUNNEL_NO_SUGGEST}" != "1" ]]; }

# ---------------- json helpers ----------------
# Transform tab-delimited rows to JSON using jq (required).
# IMPORTANT: In --json mode, commands should print ONLY JSON on stdout.
json_active_array() {
  require_jq_for_json
  active_list | jq -Rn '
    [inputs
     | split("\t")
     | {
         local: .[0],
         remote: .[1],
         pid: (.[2] | tonumber? // .[2]),
         ssh: .[3],
         name: .[4],
         created_at: .[5]
       }
    ]'
}

json_history_array() {
  # stdin: history_rows_for_prompt output:
  # ID, CREATED_AT, LOCAL, REMOTE, SSH, NAME, FAVORITE
  require_jq_for_json
  jq -Rn '
    [inputs
     | split("\t")
     | {
         id: (.[0] | tonumber? // .[0]),
         created_at: .[1],
         local: .[2],
         remote: .[3],
         ssh: .[4],
         name: .[5],
         favorite: (.[6] == "1")
       }
    ]'
}

json_open_object() {
  # args: created_at local remote pid ssh name bind private history_id
  require_jq_for_json
  local created_at="$1" localp="$2" remotep="$3" pid="$4" sshc="$5" name="$6" bind="$7" private="$8" history_id="$9"
  jq -n \
    --arg created_at "$created_at" \
    --arg local "$localp" \
    --arg remote "$remotep" \
    --arg ssh "$sshc" \
    --arg name "$name" \
    --arg bind "$bind" \
    --arg pid "$pid" \
    --argjson private "$private" \
    --arg history_id "$history_id" \
    '{
      created_at: $created_at,
      local: $local,
      remote: $remote,
      pid: ($pid | tonumber? // $pid),
      ssh: $ssh,
      name: $name,
      bind: $bind,
      private: $private
    }
    + (if ($history_id|length)>0 then {history_id: ($history_id|tonumber? // $history_id)} else {} end)
    '
}

json_close_object() {
  # args: created_at local remote pid ssh name bind
  require_jq_for_json
  local created_at="$1" localp="$2" remotep="$3" pid="$4" sshc="$5" name="$6" bind="$7"
  jq -n \
    --arg created_at "$created_at" \
    --arg local "$localp" \
    --arg remote "$remotep" \
    --arg ssh "$sshc" \
    --arg name "$name" \
    --arg bind "$bind" \
    --arg pid "$pid" \
    '{
      created_at: $created_at,
      local: $local,
      remote: $remote,
      pid: ($pid | tonumber? // $pid),
      ssh: $ssh,
      name: $name,
      bind: $bind
    }'
}

# ---------------- "did you mean" helpers ----------------
normalize_name() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr '-_.' '   ' \
    | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

name_tokens() { normalize_name "$1" | tr ' ' '\n' | awk 'NF>0{print}'; }

contains_all_tokens() {
  local needle="$1" cand="$2"
  local cand_norm
  cand_norm="$(normalize_name "$cand")"
  local t
  while read -r t; do
    [[ -n "$t" ]] || continue
    [[ "$cand_norm" == *"$t"* ]] || return 1
  done < <(name_tokens "$needle")
  return 0
}

score_candidate() {
  local needle="$1" cand="$2"
  local n c
  n="$(normalize_name "$needle")"
  c="$(normalize_name "$cand")"

  local score=0
  [[ "$c" == "$n" ]] && score=$((score + 1000))
  [[ "$c" == "$n"* ]] && score=$((score + 300))
  [[ "$c" == *"$n"* ]] && score=$((score + 200))
  contains_all_tokens "$needle" "$cand" && score=$((score + 120))

  score=$((score - ${#c}))
  printf '%s\n' "$score"
}

suggest_from_candidates() {
  local needle="$1" limit="$2"
  local scored
  scored="$(
    while IFS= read -r cand; do
      [[ -n "$cand" ]] || continue
      printf '%s\t%s\n' "$(score_candidate "$needle" "$cand")" "$cand"
    done
  )"
  printf '%s\n' "$scored" \
    | awk -F $'\t' '$1>0{print}' \
    | sort -t $'\t' -k1,1nr -k2,2 \
    | awk -F $'\t' '!seen[$2]++{print $2}' \
    | head -n "$limit"
}

print_suggestions_stderr() {
  local needle="$1" domain="$2" no_suggest_flag="${3:-0}"

  [[ "$no_suggest_flag" -eq 1 ]] && return 0
  suggestions_enabled || return 0

  local candidates=""
  case "$domain" in
    active) candidates="$(active_names_unique || true)" ;;
    history) candidates="$(history_names_unique || true)" ;;
    *) return 0 ;;
  esac
  [[ -n "$candidates" ]] || return 0

  local sug
  sug="$(
    printf '%s\n' "$candidates" | suggest_from_candidates "$needle" 3
  )"
  [[ -n "$sug" ]] || return 0

  warn "Did you mean:"
  while IFS= read -r s; do
    warn "  - $s"
  done <<<"$sug"
}

# ---------------- active tracking ----------------
active_file_for_local() { printf '%s/%s.env\n' "$RTUNNEL_ACTIVE_DIR" "$1"; }

pid_alive() {
  local pid="${1:-}"
  is_int "$pid" || return 1
  kill -0 "$pid" 2>/dev/null
}

cleanup_stale_active() {
  shopt -s nullglob
  local f pid
  for f in "$RTUNNEL_ACTIVE_DIR"/*.env; do
    pid="$(awk -F= '$1=="PID"{print $2}' "$f" 2>/dev/null || true)"
    pid="${pid//\"/}"
    if ! pid_alive "$pid"; then
      rm -f "$f" || true
    fi
  done
}

active_list() {
  shopt -s nullglob
  local f
  for f in "$RTUNNEL_ACTIVE_DIR"/*.env; do
    local LOCAL REMOTE PID SSH NAME CREATED_AT BIND
    LOCAL=""; REMOTE=""; PID=""; SSH=""; NAME=""; CREATED_AT=""; BIND=""
    load_kv_file "$f" || continue
    # keep output stable for json: include BIND at end (v0.4.0)
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "${LOCAL:-}" "${REMOTE:-}" "${PID:-}" "${SSH:-}" "${NAME:-}" "${CREATED_AT:-}" "${BIND:-}"
  done
}

active_names_unique() {
  cleanup_stale_active
  active_list | awk -F $'\t' 'NF>=5 && $5!=""{print $5}' | awk '!seen[$0]++'
}

active_find_by_name() {
  local needle="$1"
  while IFS=$'\t' read -r localp _remotep _pid _sshc name _created _bind; do
    if [[ "$name" == "$needle" ]]; then
      printf '%s\n' "$localp"
      return 0
    fi
  done < <(active_list)
  return 1
}

# ---------------- history storage ----------------
history_enabled_or_warn() {
  if [[ "$RTUNNEL_HISTORY_ENABLED" != "1" ]]; then
    warn "History is disabled (RTUNNEL_HISTORY_ENABLED=0)."
    return 1
  fi
  return 0
}

get_next_id() {
  local id
  id="$(cat "$RTUNNEL_NEXT_ID_FILE" 2>/dev/null || printf '1')"
  if ! is_int "$id"; then id=1; fi
  printf '%s\n' "$id"
}

bump_next_id() {
  local id
  id="$(get_next_id)"
  printf '%s\n' "$((id + 1))" >"$RTUNNEL_NEXT_ID_FILE"
}

history_dir_for_id() { printf '%s/%s\n' "$RTUNNEL_HISTORY_DIR" "$1"; }
history_meta_for_id() { printf '%s/meta.env\n' "$(history_dir_for_id "$1")"; }
history_args_for_id() { printf '%s/args.txt\n' "$(history_dir_for_id "$1")"; }

history_write_entry() {
  history_enabled_or_warn || return 1

  local created_at="$1" localp="$2" remotep="$3" sshc="$4" name="$5" bind="$6" fav="$7"
  shift 7
  local ssh_args=("$@")

  local id dir meta argsf
  id="$(get_next_id)"
  dir="$(history_dir_for_id "$id")"
  meta="$(history_meta_for_id "$id")"
  argsf="$(history_args_for_id "$id")"

  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true

  {
    printf 'ID=%q\n' "$id"
    printf 'CREATED_AT=%q\n' "$created_at"
    printf 'LOCAL=%q\n' "$localp"
    printf 'REMOTE=%q\n' "$remotep"
    printf 'SSH=%q\n' "$sshc"
    printf 'NAME=%q\n' "$name"
    printf 'BIND=%q\n' "$bind"
    printf 'FAVORITE=%q\n' "$fav"
  } >"$meta"
  chmod 600 "$meta" 2>/dev/null || true

  : >"$argsf"
  chmod 600 "$argsf" 2>/dev/null || true
  local a
  for a in "${ssh_args[@]}"; do
    printf '%s\n' "$a" >>"$argsf"
  done

  bump_next_id
  printf '%s\n' "$id"
}

history_load_entry() {
  local id="$1"
  local meta argsf
  meta="$(history_meta_for_id "$id")"
  argsf="$(history_args_for_id "$id")"
  [[ -f "$meta" ]] || return 1

  ID=""; CREATED_AT=""; LOCAL=""; REMOTE=""; SSH=""; NAME=""; BIND=""; FAVORITE=""
  load_kv_file "$meta" || return 1

  HISTORY_ARGS=()
  if [[ -f "$argsf" ]]; then
    mapfile -t HISTORY_ARGS <"$argsf"
  fi
}

history_iter_ids_desc() {
  shopt -s nullglob
  local d
  for d in "$RTUNNEL_HISTORY_DIR"/*; do
    [[ -d "$d" ]] || continue
    basename "$d"
  done | awk '/^[0-9]+$/{print}' | sort -nr
}

history_rows_for_prompt() {
  local id
  while read -r id; do
    history_load_entry "$id" || continue
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$ID" "$CREATED_AT" "$LOCAL" "$REMOTE" "$SSH" "$NAME" "${FAVORITE:-0}" "$BIND"
  done < <(history_iter_ids_desc)
}

history_names_unique() {
  history_enabled_or_warn || return 0
  history_iter_ids_desc | while read -r i; do
    history_load_entry "$i" || continue
    [[ -n "${NAME:-}" ]] && printf '%s\n' "$NAME"
  done | awk '!seen[$0]++'
}

resolve_id_by_name_most_recent() {
  local needle="$1"
  local id
  id="$(
    history_iter_ids_desc | while read -r i; do
      history_load_entry "$i" || continue
      if [[ "$NAME" == "$needle" ]]; then
        printf '%s\n' "$ID"
        break
      fi
    done
  )"
  [[ -n "$id" ]] || return 1
  printf '%s\n' "$id"
}

# ---------------- selection helpers ----------------
pick_history_id_prompt() {
  local name_filter="${1:-}"
  history_enabled_or_warn || return 1

  local data
  data="$(mktemp)"
  if [[ -n "$name_filter" ]]; then
    history_rows_for_prompt | awk -F $'\t' -v n="$name_filter" '$6==n{print}' >"$data"
  else
    history_rows_for_prompt >"$data"
  fi

  if [[ ! -s "$data" ]]; then
    rm -f "$data"
    return 1
  fi

  if [[ "$RTUNNEL_FZF" == "1" ]] && have fzf; then
    local picked
    picked="$(
      cat "$data" \
        | fzf --delimiter=$'\t' --with-nth=1,2,3,4,5,6,7,8 --prompt='rtunnel reopen> ' \
        | awk -F $'\t' '{print $1}'
    )"
    rm -f "$data"
    [[ -n "${picked:-}" ]] || return 1
    printf '%s\n' "$picked"
    return 0
  fi

  info "Select a history entry:"
  local i=1
  local ids=()
  while IFS=$'\t' read -r id created localp remotep sshc name fav bind; do
    printf '  [%d] id=%s  %s  %s->%s  %s  %s  fav=%s  bind=%s\n' "$i" "$id" "$created" "$localp" "$remotep" "$sshc" "$name" "$fav" "$bind"
    ids+=("$id")
    (( i++ ))
  done <"$data"

  printf '> ' >&2
  local sel
  read -r sel || true
  rm -f "$data"

  is_int "$sel" || return 1
  (( sel >= 1 && sel <= ${#ids[@]} )) || return 1
  printf '%s\n' "${ids[$((sel-1))]}"
}

# ---------------- commands ----------------
print_help() {
  cat <<EOF
rtunnel v${VERSION}

USAGE:
  rtunnel <command> [args...]

COMMANDS:
  open        Open a tunnel
  ls          List tracked open tunnels
  close       Close tunnels
  history     Show saved history
  reopen      Reopen a tunnel from history (prompt by default)
  forget      Delete a history entry
  name        Rename a history entry (by id)
  fav         Mark a history entry as favorite (by id or name)
  unfav       Unmark favorite
  favorites   List favorites

GLOBAL:
  --help      Show help
  --version   Show version

JSON:
  --json      Output JSON to stdout (requires jq). In --json mode, commands do not print human text to stdout.

OPEN:
  rtunnel open --local PORT --remote PORT --ssh USER@HOST [--name NAME] [--bind HOST] [--private] [--no-warn] [--favorite] [--replace] [--no-suggest] [--json] [-- <ssh args...>]

CLOSE:
  rtunnel close <local-port|active-name> [--force] [--no-suggest] [--json]
  rtunnel close --all [--force] [--json]
  rtunnel close --stale [--json]

HISTORY:
  rtunnel history [--name NAME] [--favorites] [--limit N] [--json]

EOF
}

cmd_ls() {
  cleanup_stale_active

  local as_json=0
  if [[ "${1:-}" == "--json" ]]; then
    as_json=1
    shift
  fi
  [[ $# -eq 0 ]] || usage_die "ls takes no arguments (except --json)"

  if [[ "$as_json" -eq 1 ]]; then
    # active_list now includes bind column; adjust json
    require_jq_for_json
    active_list | jq -Rn '
      [inputs
       | split("\t")
       | {
           local: .[0],
           remote: .[1],
           pid: (.[2] | tonumber? // .[2]),
           ssh: .[3],
           name: .[4],
           created_at: .[5],
           bind: .[6]
         }
      ]'
    return 0
  fi

  printf "%-8s %-8s %-8s %-30s %s\n" "LOCAL" "REMOTE" "PID" "SSH" "NAME"
  local any=0
  while IFS=$'\t' read -r localp remotep pid sshc name _created _bind; do
    any=1
    printf "%-8s %-8s %-8s %-30s %s\n" "$localp" "$remotep" "$pid" "$sshc" "$name"
  done < <(active_list)
  [[ "$any" -eq 0 ]] && info "No open tunnels tracked."
}

close_one_local_port() {
  # args: local_port force
  local localp="$1"
  local force="$2"

  local f
  f="$(active_file_for_local "$localp")"
  [[ -f "$f" ]] || return 1

  local LOCAL REMOTE PID SSH NAME BIND CREATED_AT
  LOCAL=""; REMOTE=""; PID=""; SSH=""; NAME=""; BIND=""; CREATED_AT=""
  load_kv_file "$f" || return 1
  PID="${PID//\"/}"

  local ok=0
  if pid_alive "$PID"; then
    kill "$PID" 2>/dev/null || true
    sleep 0.1
    if pid_alive "$PID"; then
      if [[ "$force" -eq 1 ]]; then
        kill -9 "$PID" 2>/dev/null || true
        sleep 0.05
      fi
    fi
    pid_alive "$PID" && ok=1
  fi

  rm -f "$f" || true

  # export the fields for the caller (for json)
  CLOSE_LOCAL="$LOCAL"
  CLOSE_REMOTE="$REMOTE"
  CLOSE_PID="$PID"
  CLOSE_SSH="$SSH"
  CLOSE_NAME="$NAME"
  CLOSE_BIND="$BIND"
  CLOSE_CREATED_AT="${CREATED_AT:-}"

  [[ "$ok" -eq 0 ]]
}

cmd_close() {
  cleanup_stale_active

  local force=0
  local no_suggest=0
  local as_json=0

  # parse flags for close (allow before mode selection)
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      --no-suggest) no_suggest=1; shift ;;
      --json) as_json=1; shift ;;
      --all|--stale) break ;;
      *) break ;;
    esac
  done

  if [[ "${1:-}" == "--stale" ]]; then
    shift
    [[ $# -eq 0 ]] || usage_die "close --stale takes no additional arguments"

    shopt -s nullglob
    local f pid localp
    local removed=0
    local out=""
    for f in "$RTUNNEL_ACTIVE_DIR"/*.env; do
      pid="$(awk -F= '$1=="PID"{print $2}' "$f" 2>/dev/null || true)"
      pid="${pid//\"/}"
      if ! pid_alive "$pid"; then
        localp="$(basename "$f" .env)"
        rm -f "$f" || true
        if [[ "$as_json" -eq 1 ]]; then
          out+="${localp}"$'\n'
        else
          info "Removed stale: local $localp (pid $pid)"
        fi
        removed=1
      fi
    done

    if [[ "$as_json" -eq 1 ]]; then
      require_jq_for_json
      # output array of local ports removed
      printf '%s' "$out" | jq -Rn '[inputs | select(length>0) | {local: .}]'
    else
      [[ "$removed" -eq 0 ]] && info "No stale tunnels found."
    fi
    return 0
  fi

  if [[ "${1:-}" == "--all" ]]; then
    shift
    [[ $# -eq 0 ]] || usage_die "close --all takes no additional arguments"

    cleanup_stale_active

    local any=0
    local failed=0

    if [[ "$as_json" -eq 1 ]]; then
      require_jq_for_json
      local lines=""
      while IFS=$'\t' read -r localp _remotep _pid _ssh _name _created _bind; do
        any=1
        if close_one_local_port "$localp" "$force"; then
          # success
          lines+="$CLOSE_CREATED_AT"$'\t'"$CLOSE_LOCAL"$'\t'"$CLOSE_REMOTE"$'\t'"$CLOSE_PID"$'\t'"$CLOSE_SSH"$'\t'"$CLOSE_NAME"$'\t'"$CLOSE_BIND"$'\n'
        else
          failed=1
          lines+="$CLOSE_CREATED_AT"$'\t'"$CLOSE_LOCAL"$'\t'"$CLOSE_REMOTE"$'\t'"$CLOSE_PID"$'\t'"$CLOSE_SSH"$'\t'"$CLOSE_NAME"$'\t'"$CLOSE_BIND"$'\n'
        fi
      done < <(active_list)

      # Output array of closed tunnels (best-effort). Exit code reflects failures.
      printf '%s' "$lines" | jq -Rn '
        [inputs
         | select(length>0)
         | split("\t")
         | {
             created_at: .[0],
             local: .[1],
             remote: .[2],
             pid: (.[3] | tonumber? // .[3]),
             ssh: .[4],
             name: .[5],
             bind: .[6]
           }
        ]'
      [[ "$any" -eq 0 ]] && printf '[]\n'
      [[ "$failed" -eq 0 ]] || return 1
      return 0
    fi

    while IFS=$'\t' read -r localp _remotep _pid _ssh _name _created _bind; do
      any=1
      if close_one_local_port "$localp" "$force"; then
        info "Closed: ${CLOSE_NAME:-"(unnamed)"} (local ${CLOSE_LOCAL} -> remote ${CLOSE_REMOTE} via ${CLOSE_SSH}, pid=${CLOSE_PID})"
      else
        failed=1
        warn "Failed to close tunnel at local port $localp"
      fi
    done < <(active_list)

    [[ "$any" -eq 0 ]] && info "No open tunnels tracked."
    [[ "$failed" -eq 0 ]] || return 1
    return 0
  fi

  [[ $# -ge 1 ]] || usage_die "close requires a local port, active name, or --all/--stale"
  local target="$1"
  shift
  [[ $# -eq 0 ]] || usage_die "close takes a single target (or --all/--stale)"

  local localp=""
  if is_int "$target"; then
    localp="$target"
  else
    localp="$(active_find_by_name "$target" || true)"
    if [[ -z "$localp" ]]; then
      warn "No active tunnel found with name: $target"
      print_suggestions_stderr "$target" "active" "$no_suggest"
      return 1
    fi
  fi

  if ! close_one_local_port "$localp" "$force"; then
    die "Failed to close tunnel: $target"
  fi

  if [[ "$as_json" -eq 1 ]]; then
    json_close_object "$CLOSE_CREATED_AT" "$CLOSE_LOCAL" "$CLOSE_REMOTE" "$CLOSE_PID" "$CLOSE_SSH" "$CLOSE_NAME" "$CLOSE_BIND"
  else
    info "Closed: ${CLOSE_NAME:-"(unnamed)"} (local ${CLOSE_LOCAL} -> remote ${CLOSE_REMOTE} via ${CLOSE_SSH}, pid=${CLOSE_PID})"
  fi
}

cmd_open() {
  cleanup_stale_active

  local localp="" remotep="" sshc="" name=""
  local private=0
  local bind="${RTUNNEL_DEFAULT_BIND}"
  local fav=0
  local no_warn=0
  local no_suggest=0
  local replace=0
  local as_json=0
  local passthru=()
  local positional_count=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local=*) localp="${1#--local=}" ;;
      --remote=*) remotep="${1#--remote=}" ;;
      --ssh=*) sshc="${1#--ssh=}" ;;
      --name=*) name="${1#--name=}" ;;
      --bind=*) bind="${1#--bind=}" ;;
      --private) private=1 ;;
      --favorite) fav=1 ;;
      --no-warn) no_warn=1 ;;
      --no-suggest) no_suggest=1 ;;
      --replace) replace=1 ;;
      --json) as_json=1 ;;
      --local|--remote|--ssh|--name|--bind)
        local key="$1"; shift
        [[ $# -gt 0 ]] || usage_die "missing value for $key"
        case "$key" in
          --local) localp="$1" ;;
          --remote) remotep="$1" ;;
          --ssh) sshc="$1" ;;
          --name) name="$1" ;;
          --bind) bind="$1" ;;
        esac
        ;;
      --)
        shift
        passthru=("$@")
        break
        ;;
      -*)
        usage_die "unknown option: $1 (Tip: pass ssh args after --)"
        ;;
      *)
        (( positional_count++ ))
        case "$positional_count" in
          1) localp="$1" ;;
          2) remotep="$1" ;;
          3) sshc="$1" ;;
          *) usage_die "too many positional args (Tip: pass ssh args after --)" ;;
        esac
        ;;
    esac
    shift
  done

  [[ -n "$localp" ]] || usage_die "missing --local (or positional local port)"
  [[ -n "$remotep" ]] || usage_die "missing --remote (or positional remote port)"
  [[ -n "$sshc" ]] || usage_die "missing --ssh (or positional ssh connection)"
  is_int "$localp" || usage_die "--local must be an integer"
  is_int "$remotep" || usage_die "--remote must be an integer"

  local created_at
  created_at="$(now_iso)"

  if [[ -z "$name" ]]; then
    if [[ "$replace" -eq 1 ]]; then
      usage_die "--replace requires an explicit --name"
    fi
    name="$sshc $localp->$remotep"
  fi

  # if --replace and active name exists, close it first (name-only)
  if [[ "$replace" -eq 1 ]]; then
    local existing_local
    existing_local="$(active_find_by_name "$name" || true)"
    if [[ -n "$existing_local" ]]; then
      # best-effort close
      cmd_close --force "$existing_local" >/dev/null 2>&1 || cmd_close "$existing_local" >/dev/null 2>&1 || true
    fi
  fi

  # enforce active-only name uniqueness (post-replace)
  local existing_local
  existing_local="$(active_find_by_name "$name" || true)"
  if [[ -n "$existing_local" ]]; then
    usage_die "An active tunnel already uses name '$name' (local port $existing_local). Close it first, or use --replace."
  fi

  local af
  af="$(active_file_for_local "$localp")"
  if [[ -f "$af" ]]; then
    local PID
    PID=""
    load_kv_file "$af" || true
    PID="${PID//\"/}"
    if [[ -n "$PID" ]] && pid_alive "$PID"; then
      usage_die "local port $localp is already tracked as open (pid=$PID). Run: rtunnel close $localp"
    fi
    rm -f "$af" || true
  fi

  if [[ "$private" -eq 1 ]]; then
    if [[ "$no_warn" -ne 1 ]] && warnings_enabled; then
      warn "--private disables all history/state updates; this tunnel cannot be reopened with 'rtunnel reopen'."
      warn "Set RTUNNEL_NO_WARN=1 or pass --no-warn to silence this warning."
    fi
  fi

  "$RTUNNEL_SSH_BIN" -N -L "${localp}:${bind}:${remotep}" "$sshc" "${passthru[@]}" >/dev/null 2>&1 &
  local pid="$!"

  {
    printf 'LOCAL=%q\n' "$localp"
    printf 'REMOTE=%q\n' "$remotep"
    printf 'PID=%q\n' "$pid"
    printf 'SSH=%q\n' "$sshc"
    printf 'NAME=%q\n' "$name"
    printf 'BIND=%q\n' "$bind"
    printf 'CREATED_AT=%q\n' "$created_at"
  } >"$af"
  chmod 600 "$af" 2>/dev/null || true

  local history_id=""
  if [[ "$private" -eq 0 && "$RTUNNEL_HISTORY_ENABLED" == "1" ]]; then
    history_id="$(history_write_entry "$created_at" "$localp" "$remotep" "$sshc" "$name" "$bind" "$fav" "${passthru[@]}")"
    state_set "last-opened" "$history_id"
  fi

  if [[ "$as_json" -eq 1 ]]; then
    json_open_object "$created_at" "$localp" "$remotep" "$pid" "$sshc" "$name" "$bind" "$private" "$history_id"
  else
    if [[ -n "$history_id" ]]; then
      info "Opened: $name (local $localp -> remote $remotep via $sshc, pid=$pid, history_id=$history_id)"
    else
      info "Opened: $name (local $localp -> remote $remotep via $sshc, pid=$pid, private=$private)"
    fi
  fi
}

cmd_history() {
  history_enabled_or_warn || exit 1

  local filter_name=""
  local favorites_only=0
  local limit=""
  local as_json=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        shift; [[ $# -gt 0 ]] || usage_die "missing value for --name"
        filter_name="$1"
        ;;
      --name=*) filter_name="${1#--name=}" ;;
      --favorites) favorites_only=1 ;;
      --limit)
        shift; [[ $# -gt 0 ]] || usage_die "missing value for --limit"
        limit="$1"
        ;;
      --limit=*) limit="${1#--limit=}" ;;
      --json) as_json=1 ;;
      -h|--help) usage_die "Usage: rtunnel history [--name NAME] [--favorites] [--limit N] [--json]" ;;
      *) usage_die "unknown option for history: $1" ;;
    esac
    shift
  done

  [[ -z "$limit" || $(is_int "$limit" && echo ok) ]] || usage_die "--limit must be an integer"

  if [[ "$as_json" -eq 1 ]]; then
    require_jq_for_json
    local lines=""
    local count=0
    local id
    while read -r id; do
      history_load_entry "$id" || continue
      [[ -n "$filter_name" && "$NAME" != "$filter_name" ]] && continue
      [[ "$favorites_only" -eq 1 && "${FAVORITE:-0}" != "1" ]] && continue
      lines+="$ID"$'\t'"$CREATED_AT"$'\t'"$LOCAL"$'\t'"$REMOTE"$'\t'"$SSH"$'\t'"$NAME"$'\t'"${FAVORITE:-0}"$'\t'"$BIND"$'\n'
      count=$((count + 1))
      [[ -n "$limit" && "$count" -ge "$limit" ]] && break
    done < <(history_iter_ids_desc)

    printf '%s' "$lines" | jq -Rn '
      [inputs
       | select(length>0)
       | split("\t")
       | {
           id: (.[0] | tonumber? // .[0]),
           created_at: .[1],
           local: .[2],
           remote: .[3],
           ssh: .[4],
           name: .[5],
           favorite: (.[6] == "1"),
           bind: .[7]
         }
      ]'
    return 0
  fi

  printf "%-6s %-24s %-6s %-6s %-28s %-6s %s\n" "ID" "CREATED_AT" "LOCAL" "REMOTE" "SSH" "FAV" "NAME"
  local any=0
  local count=0
  local id
  while read -r id; do
    history_load_entry "$id" || continue

    [[ -n "$filter_name" && "$NAME" != "$filter_name" ]] && continue
    [[ "$favorites_only" -eq 1 && "${FAVORITE:-0}" != "1" ]] && continue

    any=1
    printf "%-6s %-24s %-6s %-6s %-28s %-6s %s\n" "$ID" "$CREATED_AT" "$LOCAL" "$REMOTE" "$SSH" "${FAVORITE:-0}" "$NAME"
    count=$((count + 1))
    [[ -n "$limit" && "$count" -ge "$limit" ]] && break
  done < <(history_iter_ids_desc)

  [[ "$any" -eq 0 ]] && info "No history yet."
}

resolve_last_history_id() {
  local lo
  lo="$(state_get "last-opened" 2>/dev/null || true)"
  [[ -n "$lo" ]] || die "No last-opened state exists (and private tunnels are not reopenable)."
  printf '%s\n' "$lo"
}

cmd_reopen() {
  history_enabled_or_warn || exit 1

  local mode="${RTUNNEL_REOPEN_DEFAULT}"
  local want_last=0
  local name_filter=""
  local explicit_id=""
  local no_suggest=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --last) want_last=1 ;;
      --prompt) mode="prompt" ;;
      --no-suggest) no_suggest=1 ;;
      -h|--help) usage_die "Usage: rtunnel reopen [NAME|ID] [--last] [--prompt] [--no-suggest]" ;;
      *)
        if [[ -z "$name_filter" && -z "$explicit_id" ]]; then
          if is_int "$1"; then
            explicit_id="$1"
          else
            name_filter="$1"
          fi
        else
          usage_die "Too many arguments to reopen"
        fi
        ;;
    esac
    shift
  done

  local id=""
  if [[ -n "$explicit_id" ]]; then
    id="$explicit_id"
  else
    if [[ "$want_last" -eq 1 || "$mode" == "last" ]]; then
      id="$(resolve_last_history_id)"
    else
      id="$(pick_history_id_prompt "$name_filter" || true)"
      if [[ -z "$id" ]]; then
        warn "No matching history entries."
        if [[ -n "$name_filter" ]]; then
          print_suggestions_stderr "$name_filter" "history" "$no_suggest"
        fi
        exit 1
      fi
      state_set "last-selected" "$id"
    fi
  fi

  history_load_entry "$id" || die "History entry not found: $id"

  if [[ -n "$name_filter" && "$NAME" != "$name_filter" ]]; then
    warn "Selected/last entry does not match requested name '$name_filter'."
    print_suggestions_stderr "$name_filter" "history" "$no_suggest"
    exit 1
  fi

  local existing_local
  existing_local="$(active_find_by_name "$NAME" || true)"
  if [[ -n "$existing_local" ]]; then
    die "An active tunnel already uses name '$NAME' (local port $existing_local). Close it first."
  fi

  cmd_open --local="$LOCAL" --remote="$REMOTE" --ssh="$SSH" --name="$NAME" --bind "$BIND" -- "${HISTORY_ARGS[@]}"
  state_set "last-selected" "$id"
}

cmd_forget() {
  history_enabled_or_warn || exit 1
  [[ $# -ge 1 ]] || usage_die "forget requires a history id"
  local id="$1"
  is_int "$id" || usage_die "id must be an integer"
  local dir
  dir="$(history_dir_for_id "$id")"
  [[ -d "$dir" ]] || die "No history entry with id=$id"
  rm -rf "$dir"
  info "Forgot history entry id=$id"
}

cmd_name() {
  history_enabled_or_warn || exit 1
  [[ $# -ge 2 ]] || usage_die "name requires: <id> <new name>"
  local id="$1"; shift
  local new_name="$*"
  is_int "$id" || usage_die "id must be an integer"

  local meta
  meta="$(history_meta_for_id "$id")"
  [[ -f "$meta" ]] || die "No history entry with id=$id"

  history_load_entry "$id" || die "Failed to load entry"
  {
    printf 'ID=%q\n' "$ID"
    printf 'CREATED_AT=%q\n' "$CREATED_AT"
    printf 'LOCAL=%q\n' "$LOCAL"
    printf 'REMOTE=%q\n' "$REMOTE"
    printf 'SSH=%q\n' "$SSH"
    printf 'NAME=%q\n' "$new_name"
    printf 'BIND=%q\n' "$BIND"
    printf 'FAVORITE=%q\n' "${FAVORITE:-0}"
  } >"$meta"
  chmod 600 "$meta" 2>/dev/null || true

  info "Renamed history entry id=$id to: $new_name"
}

set_favorite() {
  local id="$1" fav="$2"
  history_load_entry "$id" || die "No history entry with id=$id"
  local meta
  meta="$(history_meta_for_id "$id")"
  {
    printf 'ID=%q\n' "$ID"
    printf 'CREATED_AT=%q\n' "$CREATED_AT"
    printf 'LOCAL=%q\n' "$LOCAL"
    printf 'REMOTE=%q\n' "$REMOTE"
    printf 'SSH=%q\n' "$SSH"
    printf 'NAME=%q\n' "$NAME"
    printf 'BIND=%q\n' "$BIND"
    printf 'FAVORITE=%q\n' "$fav"
  } >"$meta"
  chmod 600 "$meta" 2>/dev/null || true
}

cmd_fav() {
  history_enabled_or_warn || exit 1
  local no_suggest=0
  if [[ "${1:-}" == "--no-suggest" ]]; then
    no_suggest=1
    shift
  fi

  local as_json=0
  if [[ "${1:-}" == "--json" ]]; then
    as_json=1
    shift
  fi

  [[ $# -ge 1 ]] || usage_die "fav requires a history id or name"
  local target="$1"
  local id=""
  if is_int "$target"; then
    id="$target"
  else
    id="$(resolve_id_by_name_most_recent "$target" || true)"
    if [[ -z "$id" ]]; then
      warn "No history entry found with name: $target"
      print_suggestions_stderr "$target" "history" "$no_suggest"
      exit 1
    fi
  fi
  set_favorite "$id" "1"

  if [[ "$as_json" -eq 1 ]]; then
    # output the updated entry object
    history_load_entry "$id" || die "History entry not found: $id"
    require_jq_for_json
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$ID" "$CREATED_AT" "$LOCAL" "$REMOTE" "$SSH" "$NAME" "${FAVORITE:-0}" "$BIND" \
      | jq -Rn 'inputs | split("\t") | {id:(.[0]|tonumber?//.[0]),created_at:.[1],local:.[2],remote:.[3],ssh:.[4],name:.[5],favorite:(.[6]=="1"),bind:.[7]}'
  else
    info "Favorited: id=$id"
  fi
}

cmd_unfav() {
  history_enabled_or_warn || exit 1
  local no_suggest=0
  if [[ "${1:-}" == "--no-suggest" ]]; then
    no_suggest=1
    shift
  fi

  local as_json=0
  if [[ "${1:-}" == "--json" ]]; then
    as_json=1
    shift
  fi

  [[ $# -ge 1 ]] || usage_die "unfav requires a history id or name"
  local target="$1"
  local id=""
  if is_int "$target"; then
    id="$target"
  else
    id="$(resolve_id_by_name_most_recent "$target" || true)"
    if [[ -z "$id" ]]; then
      warn "No history entry found with name: $target"
      print_suggestions_stderr "$target" "history" "$no_suggest"
      exit 1
    fi
  fi
  set_favorite "$id" "0"

  if [[ "$as_json" -eq 1 ]]; then
    history_load_entry "$id" || die "History entry not found: $id"
    require_jq_for_json
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$ID" "$CREATED_AT" "$LOCAL" "$REMOTE" "$SSH" "$NAME" "${FAVORITE:-0}" "$BIND" \
      | jq -Rn 'inputs | split("\t") | {id:(.[0]|tonumber?//.[0]),created_at:.[1],local:.[2],remote:.[3],ssh:.[4],name:.[5],favorite:(.[6]=="1"),bind:.[7]}'
  else
    info "Unfavorited: id=$id"
  fi
}

cmd_favorites() {
  history_enabled_or_warn || exit 1

  local as_json=0
  if [[ "${1:-}" == "--json" ]]; then
    as_json=1
    shift
  fi
  [[ $# -eq 0 ]] || usage_die "favorites takes no arguments (except --json)"

  if [[ "$as_json" -eq 1 ]]; then
    require_jq_for_json
    local lines=""
    local id
    while read -r id; do
      history_load_entry "$id" || continue
      [[ "${FAVORITE:-0}" == "1" ]] || continue
      lines+="$ID"$'\t'"$CREATED_AT"$'\t'"$LOCAL"$'\t'"$REMOTE"$'\t'"$SSH"$'\t'"$NAME"$'\t'"${FAVORITE:-0}"$'\t'"$BIND"$'\n'
    done < <(history_iter_ids_desc)

    printf '%s' "$lines" | jq -Rn '
      [inputs
       | select(length>0)
       | split("\t")
       | {
           id: (.[0] | tonumber? // .[0]),
           created_at: .[1],
           local: .[2],
           remote: .[3],
           ssh: .[4],
           name: .[5],
           favorite: (.[6] == "1"),
           bind: .[7]
         }
      ]'
    return 0
  fi

  printf "%-6s %-24s %-6s %-6s %-28s %-6s %s\n" "ID" "CREATED_AT" "LOCAL" "REMOTE" "SSH" "FAV" "NAME"
  local any=0
  local id
  while read -r id; do
    history_load_entry "$id" || continue
    if [[ "${FAVORITE:-0}" == "1" ]]; then
      any=1
      printf "%-6s %-24s %-6s %-6s %-28s %-6s %s\n" "$ID" "$CREATED_AT" "$LOCAL" "$REMOTE" "$SSH" "${FAVORITE:-0}" "$NAME"
    fi
  done < <(history_iter_ids_desc)
  [[ "$any" -eq 0 ]] && info "No favorites yet."
}

# ---------------- main ----------------
init_config

case "${1:-}" in
  --help|-h|help) print_help; exit 0 ;;
  --version) info "$VERSION"; exit 0 ;;
  open) shift; cmd_open "$@" ;;
  ls|list) shift; cmd_ls "$@" ;;
  close) shift; cmd_close "$@" ;;
  history) shift; cmd_history "$@" ;;
  reopen) shift; cmd_reopen "$@" ;;
  forget) shift; cmd_forget "$@" ;;
  name) shift; cmd_name "$@" ;;
  fav) shift; cmd_fav "$@" ;;
  unfav) shift; cmd_unfav "$@" ;;
  favorites) shift; cmd_favorites "$@" ;;
  "") print_help; exit 0 ;;
  *) usage_die "unknown command: $1" ;;
esac
